{
  "name": "insee-company-search",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "python -m uvicorn backend.app:app --host 127.0.0.1 --port 8080 --reload",
    "build": "vite build",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest",
    "test:vies": "node test_vies_direct.mjs",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:fullflow": "node test_full_flow.mjs 20",
    "test:fullflow:all": "node test_full_flow.mjs 0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "idb-keyval": "^6.2.2",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.3.0",
    "happy-dom": "^20.4.0",
    "jsdom": "^27.4.0",
    "vite": "^6.0.11",
    "vitest": "^4.1.2"
  },
  "knip": {
    "ignoreBinaries": [
      "python"
    ]
  }
}
